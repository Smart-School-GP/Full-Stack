generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model School {
  id               String            @id @default(uuid())
  name             String
  city             String?
  country          String?
  createdAt        DateTime          @default(now()) @map("created_at")
  analyticsJobs    AnalyticsJob[]
  analyticsReports AnalyticsReport[]
  classes          Class[]
  meetings         Meeting[]
  notifications    Notification[]
  subjectInsights  SubjectInsight[]
  users            User[]
  attendance       Attendance[]
  conversations    Conversation[]
  announcements    Announcement[]

  @@map("schools")
}

model User {
  id              String          @id @default(uuid())
  schoolId        String          @map("school_id")
  name            String
  email           String          @unique
  passwordHash    String          @map("password_hash")
  role            String
  createdAt       DateTime        @default(now()) @map("created_at")
  finalGrades     FinalGrade[]
  grades          Grade[]
  studentMeetings Meeting[]       @relation("StudentMeetings")
  parentMeetings  Meeting[]       @relation("ParentMeetings")
  teacherMeetings Meeting[]       @relation("TeacherMeetings")
  notifications   Notification[]  @relation("ReceivedNotifications")
  studentParents  ParentStudent[] @relation("StudentRelation")
  parentStudents  ParentStudent[] @relation("ParentRelation")
  riskScores      RiskScore[]
  studentClasses  StudentClass[]
  teacherSubjects Subject[]
  teacherClasses  TeacherClass[]
  school          School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  markedAttendance Attendance[]   @relation("MarkedByUser")
  attendance       Attendance[]   @relation("StudentAttendance")
  submissions       Submission[]
  teacherConversations Conversation[] @relation("TeacherConversations")
  parentConversations Conversation[] @relation("ParentConversations")
  studentConversations Conversation[] @relation("StudentConversations")
  messages        Message[]
  announcements   Announcement[]  @relation("AnnouncementCreator")
  announcementReads AnnouncementRead[]
  deviceTokens    DeviceToken[]

  @@map("users")
}

model Class {
  id              String           @id @default(uuid())
  schoolId        String           @map("school_id")
  name            String
  gradeLevel      Int?             @map("grade_level")
  createdAt       DateTime         @default(now()) @map("created_at")
  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students        StudentClass[]
  subjectInsights SubjectInsight[]
  subjects        Subject[]
  teachers        TeacherClass[]
  attendance      Attendance[]

  @@map("classes")
}

model StudentClass {
  studentId String @map("student_id")
  classId   String @map("class_id")
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([studentId, classId])
  @@map("student_classes")
}

model TeacherClass {
  teacherId String @map("teacher_id")
  classId   String @map("class_id")
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher   User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@id([teacherId, classId])
  @@map("teacher_classes")
}

model Subject {
  id               String            @id @default(uuid())
  classId          String            @map("class_id")
  teacherId        String?           @map("teacher_id")
  name             String
  createdAt        DateTime          @default(now()) @map("created_at")
  assignments      Assignment[]
  finalGrades      FinalGrade[]
  gradingAlgorithm GradingAlgorithm?
  riskScores       RiskScore[]
  subjectInsights  SubjectInsight[]
  teacher          User?             @relation(fields: [teacherId], references: [id])
  class            Class             @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("subjects")
}

model GradingAlgorithm {
  id        String   @id @default(uuid())
  subjectId String   @unique @map("subject_id")
  weights   String
  updatedAt DateTime @updatedAt @map("updated_at")
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@map("grading_algorithms")
}

model Assignment {
  id              String   @id @default(uuid())
  subjectId       String   @map("subject_id")
  title           String
  type            String
  maxScore        Float    @default(100) @map("max_score")
  dueDate         DateTime? @map("due_date")
  submissionType  String?  @map("submission_type")
  instructions    String?
  createdAt       DateTime @default(now()) @map("created_at")
  subject         Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  grades          Grade[]
  submissions     Submission[]

  @@map("assignments")
}

model Grade {
  id           String     @id @default(uuid())
  studentId    String     @map("student_id")
  assignmentId String     @map("assignment_id")
  score        Float
  createdAt    DateTime   @default(now()) @map("created_at")
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, assignmentId])
  @@map("grades")
}

model FinalGrade {
  id         String   @id @default(uuid())
  studentId  String   @map("student_id")
  subjectId  String   @map("subject_id")
  finalScore Float?   @map("final_score")
  updatedAt  DateTime @updatedAt @map("updated_at")
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@map("final_grades")
}

model ParentStudent {
  parentId  String @map("parent_id")
  studentId String @map("student_id")
  student   User   @relation("StudentRelation", fields: [studentId], references: [id], onDelete: Cascade)
  parent    User   @relation("ParentRelation", fields: [parentId], references: [id], onDelete: Cascade)

  @@id([parentId, studentId])
  @@map("parent_students")
}

model RiskScore {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  subjectId    String   @map("subject_id")
  riskScore    Float    @map("risk_score")
  riskLevel    String   @map("risk_level")
  calculatedAt DateTime @default(now()) @map("calculated_at")
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  student      User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@map("risk_scores")
}

model Notification {
  id          String   @id @default(uuid())
  schoolId    String   @map("school_id")
  recipientId String   @map("recipient_id")
  type        String
  title       String
  body        String
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")
  recipient   User     @relation("ReceivedNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Meeting {
  id              String   @id @default(uuid())
  schoolId        String   @map("school_id")
  teacherId       String   @map("teacher_id")
  parentId        String   @map("parent_id")
  studentId       String   @map("student_id")
  roomUrl         String?  @map("room_url")
  roomName        String?  @map("room_name")
  scheduledAt     DateTime @map("scheduled_at")
  durationMinutes Int      @default(30) @map("duration_minutes")
  status          String   @default("scheduled")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  student         User     @relation("StudentMeetings", fields: [studentId], references: [id])
  parent          User     @relation("ParentMeetings", fields: [parentId], references: [id])
  teacher         User     @relation("TeacherMeetings", fields: [teacherId], references: [id])
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("meetings")
}

model AnalyticsReport {
  id                  String   @id @default(uuid())
  schoolId            String   @map("school_id")
  reportType          String   @default("manual") @map("report_type")
  schoolSummary       String?  @map("school_summary")
  atRiskSummary       String?  @map("at_risk_summary")
  recommendedActions  String   @default("[]") @map("recommended_actions")
  subjectInsightsJson String   @default("[]") @map("subject_insights_json")
  generatedAt         DateTime @default(now()) @map("generated_at")
  weekStart           String   @map("week_start")
  school              School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, weekStart])
  @@map("analytics_reports")
}

model SubjectInsight {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  subjectId    String   @map("subject_id")
  classId      String   @map("class_id")
  insightText  String   @map("insight_text")
  averageScore Float?   @map("average_score")
  trend        String   @default("stable")
  generatedAt  DateTime @default(now()) @map("generated_at")
  class        Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("subject_insights")
}

model AnalyticsJob {
  id           String    @id @default(uuid())
  schoolId     String    @map("school_id")
  status       String    @default("pending")
  triggeredBy  String    @default("admin") @map("triggered_by")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("analytics_jobs")
}

model Attendance {
  id          String   @id @default(uuid())
  schoolId    String   @map("school_id")
  studentId   String   @map("student_id")
  classId     String   @map("class_id")
  date        DateTime
  status      String
  markedBy    String?  @map("marked_by")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     User     @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  markedByUser User?   @relation("MarkedByUser", fields: [markedBy], references: [id])
  
  @@unique([studentId, date])
  @@map("attendance")
}

model Conversation {
  id           String    @id @default(uuid())
  schoolId     String    @map("school_id")
  teacherId    String    @map("teacher_id")
  parentId     String    @map("parent_id")
  studentId    String    @map("student_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastMessageAt DateTime? @map("last_message_at")
  
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher      User      @relation("TeacherConversations", fields: [teacherId], references: [id])
  parent       User      @relation("ParentConversations", fields: [parentId], references: [id])
  student      User      @relation("StudentConversations", fields: [studentId], references: [id])
  messages     Message[]
  
  @@unique([teacherId, parentId, studentId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  senderId       String       @map("sender_id")
  body           String
  attachmentUrl  String?      @map("attachment_url")
  attachmentType String?      @map("attachment_type")
  isRead         Boolean      @default(false) @map("is_read")
  createdAt      DateTime     @default(now()) @map("created_at")
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])
  
  @@map("messages")
}

model Submission {
  id            String    @id @default(uuid())
  assignmentId  String    @map("assignment_id")
  studentId     String    @map("student_id")
  fileUrl       String?   @map("file_url")
  fileName      String?   @map("file_name")
  fileType      String?   @map("file_type")
  textResponse  String?   @map("text_response")
  submittedAt   DateTime  @default(now()) @map("submitted_at")
  status        String    @default("submitted")
  feedback      String?
  score         Float?
  
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  @@unique([assignmentId, studentId])
  @@map("submissions")
}

model Announcement {
  id          String    @id @default(uuid())
  schoolId    String    @map("school_id")
  createdBy   String    @map("created_by")
  title       String
  body        String
  audience    String
  pinned      Boolean   @default(false)
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  creator     User      @relation("AnnouncementCreator", fields: [createdBy], references: [id])
  reads       AnnouncementRead[]
  
  @@map("announcements")
}

model AnnouncementRead {
  announcementId String      @map("announcement_id")
  userId         String      @map("user_id")
  readAt         DateTime    @default(now()) @map("read_at")
  
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])
  
  @@id([announcementId, userId])
  @@map("announcement_reads")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String
  platform  String
  createdAt DateTime @default(now()) @map("created_at")
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, token])
  @@map("device_tokens")
}
