# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite path inside the backend container (do not change when using Docker)
DATABASE_URL=file:/app/data/school.db

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── Service URLs ────────────────────────────────────────────────────────────
# These are used by the frontend to talk to the backend
NEXT_PUBLIC_API_URL=http://localhost:4000
# Python AI microservice (FastAPI, port 8002)
AI_SERVICE_URL=http://localhost:8002
