# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"
DATABASE_PROVIDER=sqlite

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=this_is_a_very_long_and_secret_random_string_32_chars_long
JWT_EXPIRES_IN=1d

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Service URLs ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8002

# ─── Monitoring & Alerting ───────────────────────────────────────────────────
SENTRY_DSN=

# ─── Email (for password reset) ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourschool.com

# ─── File uploads ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20

# ─── Cron ────────────────────────────────────────────────────────────────────
CRON_TIMEZONE=UTC

# ─── AI Service ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyC6autu5KeLdBvcEsWCHn2-YVPjViOdhdg

