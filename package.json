{
  "name": "school-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --names \"BACKEND,FRONTEND,AI_SERVICE\" --prefix-colors \"blue.bold,cyan.bold,magenta.bold\" --prefix \"[{name}]\" \"npm:server\" \"npm:client\" \"npm:ai-service\"",
    "server": "nodemon backend/server.js",
    "ai-service": "cd ai-service && ../ai-service/venv/bin/python run.py",
    "client": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:select-provider": "node backend/scripts/set-prisma-provider.js",
    "prisma:generate": "npm run db:select-provider && prisma generate",
    "prisma:migrate": "npm run db:select-provider && prisma migrate deploy",
    "prisma:push": "npm run db:select-provider && prisma db push",
    "seed": "node backend/prisma/seed.js",
    "setup": "npm run db:select-provider && prisma generate && prisma db push && node backend/prisma/seed.js",
    "test": "jest"
  },
  "prisma": {
    "seed": "node backend/prisma/seed.js"
  },
  "dependencies": {
    "@daily-co/daily-js": "^0.54.0",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@headlessui/react": "^2.2.10",
    "@hello-pangea/dnd": "^18.0.1",
    "@prisma/client": "^5.7.0",
    "@sentry/node": "^10.49.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.2",
    "cloudinary": "^2.9.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "file-saver": "^2.0.5",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "idb": "^8.0.3",
    "isomorphic-dompurify": "^3.7.1",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "multer": "^2.1.1",
    "next": "14.0.4",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.5",
    "prom-client": "^15.1.3",
    "react": "^18",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18",
    "react-quill": "^2.0.0",
    "recharts": "^2.10.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "postcss": "^8",
    "prisma": "^5.7.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  }
}
