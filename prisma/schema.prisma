generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Development: sqlite  Production: change to postgresql
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model School {
  id               String            @id @default(uuid())
  name             String
  city             String?
  country          String?
  createdAt        DateTime          @default(now()) @map("created_at")
  analyticsJobs    AnalyticsJob[]
  analyticsReports AnalyticsReport[]
  classes          Class[]
  meetings         Meeting[]
  notifications    Notification[]
  subjectInsights  SubjectInsight[]
  users            User[]
  attendance       Attendance[]
  conversations    Conversation[]
  announcements    Announcement[]
  // Phase 6
  learningPaths    LearningPath[]
  discussionBoards DiscussionBoard[]
  badgeDefinitions BadgeDefinition[]
  portfolioItems   PortfolioItem[]
  timetablePeriods TimetablePeriod[]
  timetableSlots   TimetableSlot[]
  schoolEvents     SchoolEvent[]
  riskScores       RiskScore[]

  @@map("schools")
}

model User {
  id                     String    @id @default(uuid())
  schoolId               String    @map("school_id")
  name                   String
  email                  String    @unique
  passwordHash           String    @map("password_hash")
  role                   String
  isActive               Boolean   @default(true) @map("is_active")
  passwordResetToken     String?   @map("password_reset_token")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  lastPasswordChange     DateTime? @map("last_password_change")
  createdAt              DateTime  @default(now()) @map("created_at")
  finalGrades     FinalGrade[]
  grades          Grade[]
  studentMeetings Meeting[]       @relation("StudentMeetings")
  parentMeetings  Meeting[]       @relation("ParentMeetings")
  teacherMeetings Meeting[]       @relation("TeacherMeetings")
  notifications   Notification[]  @relation("ReceivedNotifications")
  studentParents  ParentStudent[] @relation("StudentRelation")
  parentStudents  ParentStudent[] @relation("ParentRelation")
  riskScores      RiskScore[]
  studentClasses  StudentClass[]
  teacherSubjects Subject[]
  teacherClasses  TeacherClass[]
  school          School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  markedAttendance Attendance[]   @relation("MarkedByUser")
  attendance       Attendance[]   @relation("StudentAttendance")
  submissions       Submission[]
  teacherConversations Conversation[] @relation("TeacherConversations")
  parentConversations Conversation[] @relation("ParentConversations")
  studentConversations Conversation[] @relation("StudentConversations")
  messages        Message[]
  announcements   Announcement[]  @relation("AnnouncementCreator")
  announcementReads AnnouncementRead[]
  deviceTokens    DeviceToken[]
  // Phase 6
  teacherPaths        LearningPath[]    @relation("TeacherPaths")
  pathProgress        PathProgress[]
  boardsCreated       DiscussionBoard[] @relation("BoardCreator")
  threadsAuthored     DiscussionThread[] @relation("ThreadAuthor")
  repliesAuthored     DiscussionReply[] @relation("ReplyAuthor")
  replyUpvotes        ReplyUpvote[]
  earnedBadges        StudentBadge[]    @relation("EarnedBadges")
  awardedBadges       StudentBadge[]    @relation("AwardedBadges")
  portfolioItems      PortfolioItem[]   @relation("StudentPortfolio")
  studentXP           StudentXP?        @relation("StudentXP")
  timetableSlots      TimetableSlot[]   @relation("TeacherSlots")
  eventsCreated       SchoolEvent[]     @relation("EventCreator")

  @@index([schoolId])
  @@map("users")
}

model Class {
  id              String           @id @default(uuid())
  schoolId        String           @map("school_id")
  name            String
  gradeLevel      Int?             @map("grade_level")
  createdAt       DateTime         @default(now()) @map("created_at")
  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students        StudentClass[]
  subjectInsights SubjectInsight[]
  subjects        Subject[]
  teachers        TeacherClass[]
  attendance      Attendance[]
  // Phase 6
  discussionBoards DiscussionBoard[]
  timetableSlots   TimetableSlot[]

  @@map("classes")
}

model StudentClass {
  studentId String @map("student_id")
  classId   String @map("class_id")
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([studentId, classId])
  @@map("student_classes")
}

model TeacherClass {
  teacherId String @map("teacher_id")
  classId   String @map("class_id")
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher   User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@id([teacherId, classId])
  @@map("teacher_classes")
}

model Subject {
  id               String            @id @default(uuid())
  classId          String            @map("class_id")
  teacherId        String?           @map("teacher_id")
  name             String
  createdAt        DateTime          @default(now()) @map("created_at")
  assignments      Assignment[]
  finalGrades      FinalGrade[]
  gradingAlgorithm GradingAlgorithm?
  riskScores       RiskScore[]
  subjectInsights  SubjectInsight[]
  teacher          User?             @relation(fields: [teacherId], references: [id])
  class            Class             @relation(fields: [classId], references: [id], onDelete: Cascade)

  // Phase 6
  learningPaths    LearningPath[]
  discussionBoards DiscussionBoard[]
  portfolioItems   PortfolioItem[]
  timetableSlots   TimetableSlot[]

  @@map("subjects")
}

model GradingAlgorithm {
  id        String   @id @default(uuid())
  subjectId String   @unique @map("subject_id")
  weights   String
  updatedAt DateTime @updatedAt @map("updated_at")
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@map("grading_algorithms")
}

model Assignment {
  id              String   @id @default(uuid())
  subjectId       String   @map("subject_id")
  title           String
  type            String
  maxScore        Float    @default(100) @map("max_score")
  dueDate         DateTime? @map("due_date")
  submissionType  String?  @map("submission_type")
  instructions    String?
  createdAt       DateTime @default(now()) @map("created_at")
  subject         Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  grades          Grade[]
  submissions     Submission[]

  @@map("assignments")
}

model Grade {
  id           String     @id @default(uuid())
  studentId    String     @map("student_id")
  assignmentId String     @map("assignment_id")
  score        Float
  createdAt    DateTime   @default(now()) @map("created_at")
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, assignmentId])
  @@index([studentId])
  @@index([assignmentId])
  @@index([createdAt])
  @@map("grades")
}

model FinalGrade {
  id         String   @id @default(uuid())
  studentId  String   @map("student_id")
  subjectId  String   @map("subject_id")
  finalScore Float?   @map("final_score")
  updatedAt  DateTime @updatedAt @map("updated_at")
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@map("final_grades")
}

model ParentStudent {
  parentId  String @map("parent_id")
  studentId String @map("student_id")
  student   User   @relation("StudentRelation", fields: [studentId], references: [id], onDelete: Cascade)
  parent    User   @relation("ParentRelation", fields: [parentId], references: [id], onDelete: Cascade)

  @@id([parentId, studentId])
  @@map("parent_students")
}

model RiskScore {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  studentId    String   @map("student_id")
  subjectId    String   @map("subject_id")
  riskScore    Float    @map("risk_score")
  riskLevel    String   @map("risk_level")
  trend        String?  @default("stable")
  confidence   Float?
  // SHAP / rule-based per-feature contributions. JSON-encoded array of
  // {feature, label, value, contribution, normalized, direction}. SQLite
  // has no JSON column, so we store as TEXT and parse at the service layer.
  explanations String?  @map("explanations")
  calculatedAt DateTime @default(now()) @map("calculated_at")
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  student      User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@index([studentId, subjectId])
  @@index([riskLevel])
  @@index([schoolId])
  @@map("risk_scores")
}

model Notification {
  id          String   @id @default(uuid())
  schoolId    String   @map("school_id")
  recipientId String   @map("recipient_id")
  type        String
  title       String
  body        String
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")
  recipient   User     @relation("ReceivedNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([schoolId])
  @@map("notifications")
}

model Meeting {
  id              String   @id @default(uuid())
  schoolId        String   @map("school_id")
  teacherId       String   @map("teacher_id")
  parentId        String   @map("parent_id")
  studentId       String   @map("student_id")
  roomUrl         String?  @map("room_url")
  roomName        String?  @map("room_name")
  scheduledAt     DateTime @map("scheduled_at")
  durationMinutes Int      @default(30) @map("duration_minutes")
  status          String   @default("scheduled")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  student         User     @relation("StudentMeetings", fields: [studentId], references: [id])
  parent          User     @relation("ParentMeetings", fields: [parentId], references: [id])
  teacher         User     @relation("TeacherMeetings", fields: [teacherId], references: [id])
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([teacherId])
  @@index([parentId])
  @@map("meetings")
}

model AnalyticsReport {
  id                  String   @id @default(uuid())
  schoolId            String   @map("school_id")
  reportType          String   @default("manual") @map("report_type")
  schoolSummary       String?  @map("school_summary")
  atRiskSummary       String?  @map("at_risk_summary")
  recommendedActions  String   @default("[]") @map("recommended_actions")
  subjectInsightsJson String   @default("[]") @map("subject_insights_json")
  generatedAt         DateTime @default(now()) @map("generated_at")
  weekStart           String   @map("week_start")
  school              School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, weekStart])
  @@map("analytics_reports")
}

model SubjectInsight {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  subjectId    String   @map("subject_id")
  classId      String   @map("class_id")
  insightText  String   @map("insight_text")
  averageScore Float?   @map("average_score")
  trend        String   @default("stable")
  generatedAt  DateTime @default(now()) @map("generated_at")
  class        Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("subject_insights")
}

model AnalyticsJob {
  id           String    @id @default(uuid())
  schoolId     String    @map("school_id")
  status       String    @default("pending")
  triggeredBy  String    @default("admin") @map("triggered_by")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("analytics_jobs")
}

model Attendance {
  id          String   @id @default(uuid())
  schoolId    String   @map("school_id")
  studentId   String   @map("student_id")
  classId     String   @map("class_id")
  date        DateTime
  status      String
  markedBy    String?  @map("marked_by")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     User     @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  markedByUser User?   @relation("MarkedByUser", fields: [markedBy], references: [id])
  
  @@unique([studentId, date])
  @@index([studentId])
  @@index([classId, date])
  @@index([schoolId])
  @@map("attendance")
}

model Conversation {
  id           String    @id @default(uuid())
  schoolId     String    @map("school_id")
  teacherId    String    @map("teacher_id")
  parentId     String    @map("parent_id")
  studentId    String    @map("student_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastMessageAt DateTime? @map("last_message_at")
  
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher      User      @relation("TeacherConversations", fields: [teacherId], references: [id])
  parent       User      @relation("ParentConversations", fields: [parentId], references: [id])
  student      User      @relation("StudentConversations", fields: [studentId], references: [id])
  messages     Message[]
  
  @@unique([teacherId, parentId, studentId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([parentId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  senderId       String       @map("sender_id")
  body           String
  attachmentUrl  String?      @map("attachment_url")
  attachmentType String?      @map("attachment_type")
  isRead         Boolean      @default(false) @map("is_read")
  createdAt      DateTime     @default(now()) @map("created_at")
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])
  
  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

model Submission {
  id            String    @id @default(uuid())
  assignmentId  String    @map("assignment_id")
  studentId     String    @map("student_id")
  fileUrl       String?   @map("file_url")
  fileName      String?   @map("file_name")
  fileType      String?   @map("file_type")
  textResponse  String?   @map("text_response")
  submittedAt   DateTime  @default(now()) @map("submitted_at")
  status        String    @default("submitted")
  feedback      String?
  score         Float?
  
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([assignmentId])
  @@map("submissions")
}

model Announcement {
  id          String    @id @default(uuid())
  schoolId    String    @map("school_id")
  createdBy   String    @map("created_by")
  title       String
  body        String
  audience    String
  pinned      Boolean   @default(false)
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  creator     User      @relation("AnnouncementCreator", fields: [createdBy], references: [id])
  reads       AnnouncementRead[]
  
  @@index([schoolId])
  @@index([expiresAt])
  @@map("announcements")
}

model AnnouncementRead {
  announcementId String      @map("announcement_id")
  userId         String      @map("user_id")
  readAt         DateTime    @default(now()) @map("read_at")
  
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])
  
  @@id([announcementId, userId])
  @@map("announcement_reads")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String
  platform  String
  createdAt DateTime @default(now()) @map("created_at")
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, token])
  @@map("device_tokens")
}

// ─── Phase 6: LMS Models ────────────────────────────────────────────────────

model LearningPath {
  id          String       @id @default(uuid())
  schoolId    String       @map("school_id")
  subjectId   String       @map("subject_id")
  teacherId   String       @map("teacher_id")
  title       String
  description String?
  isPublished Boolean      @default(false) @map("is_published")
  orderIndex  Int          @default(0) @map("order_index")
  createdAt   DateTime     @default(now()) @map("created_at")
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject     Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     User         @relation("TeacherPaths", fields: [teacherId], references: [id])
  modules     PathModule[]

  @@map("learning_paths")
}

model PathModule {
  id                String     @id @default(uuid())
  pathId            String     @map("path_id")
  title             String
  description       String?
  orderIndex        Int        @map("order_index")
  unlockCondition   String     @default("sequential") @map("unlock_condition")
  minScoreToUnlock  Float?     @map("min_score_to_unlock")
  createdAt         DateTime   @default(now()) @map("created_at")
  path              LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  items             PathItem[]

  @@map("path_modules")
}

model PathItem {
  id          String        @id @default(uuid())
  moduleId    String        @map("module_id")
  title       String
  type        String
  content     String?
  fileUrl     String?       @map("file_url")
  externalUrl String?       @map("external_url")
  orderIndex  Int           @map("order_index")
  isRequired  Boolean       @default(true) @map("is_required")
  points      Int           @default(0)
  createdAt   DateTime      @default(now()) @map("created_at")
  module      PathModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    PathProgress[]

  @@map("path_items")
}

model PathProgress {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  itemId      String   @map("item_id")
  status      String   @default("not_started")
  score       Float?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  item        PathItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([studentId, itemId])
  @@map("path_progress")
}

model DiscussionBoard {
  id          String             @id @default(uuid())
  schoolId    String             @map("school_id")
  subjectId   String?            @map("subject_id")
  classId     String?            @map("class_id")
  title       String
  description String?
  isPinned    Boolean            @default(false) @map("is_pinned")
  isLocked    Boolean            @default(false) @map("is_locked")
  type        String             @default("general")
  createdBy   String             @map("created_by")
  createdAt   DateTime           @default(now()) @map("created_at")
  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject     Subject?           @relation(fields: [subjectId], references: [id])
  class       Class?             @relation(fields: [classId], references: [id])
  creator     User               @relation("BoardCreator", fields: [createdBy], references: [id])
  threads     DiscussionThread[]

  @@map("discussion_boards")
}

model DiscussionThread {
  id        String            @id @default(uuid())
  boardId   String            @map("board_id")
  authorId  String            @map("author_id")
  title     String
  body      String
  isPinned  Boolean           @default(false) @map("is_pinned")
  isLocked  Boolean           @default(false) @map("is_locked")
  views     Int               @default(0)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  board     DiscussionBoard   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  author    User              @relation("ThreadAuthor", fields: [authorId], references: [id])
  replies   DiscussionReply[]

  @@map("discussion_threads")
}

model DiscussionReply {
  id               String          @id @default(uuid())
  threadId         String          @map("thread_id")
  parentReplyId    String?         @map("parent_reply_id")
  authorId         String          @map("author_id")
  body             String
  isAcceptedAnswer Boolean         @default(false) @map("is_accepted_answer")
  upvotes          Int             @default(0)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  thread           DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author           User             @relation("ReplyAuthor", fields: [authorId], references: [id])
  parentReply      DiscussionReply? @relation("ReplyReplies", fields: [parentReplyId], references: [id])
  childReplies     DiscussionReply[] @relation("ReplyReplies")
  replyUpvotes     ReplyUpvote[]

  @@map("discussion_replies")
}

model ReplyUpvote {
  userId    String          @map("user_id")
  replyId   String          @map("reply_id")
  createdAt DateTime        @default(now()) @map("created_at")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply     DiscussionReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@id([userId, replyId])
  @@map("reply_upvotes")
}

model BadgeDefinition {
  id            String         @id @default(uuid())
  schoolId      String         @map("school_id")
  name          String
  description   String?
  iconUrl       String?        @map("icon_url")
  iconEmoji     String?        @map("icon_emoji")
  color         String?
  criteriaType  String         @map("criteria_type")
  criteriaValue Float?         @map("criteria_value")
  pointsValue   Int            @default(10) @map("points_value")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentBadges StudentBadge[]

  @@map("badge_definitions")
}

model StudentBadge {
  id        String          @id @default(uuid())
  studentId String          @map("student_id")
  badgeId   String          @map("badge_id")
  awardedBy String?         @map("awarded_by")
  awardedAt DateTime        @default(now()) @map("awarded_at")
  note      String?
  student   User            @relation("EarnedBadges", fields: [studentId], references: [id], onDelete: Cascade)
  badge     BadgeDefinition @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awarder   User?           @relation("AwardedBadges", fields: [awardedBy], references: [id])

  @@unique([studentId, badgeId])
  @@map("student_badges")
}

model PortfolioItem {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  schoolId     String   @map("school_id")
  title        String
  description  String?
  type         String
  fileUrl      String?  @map("file_url")
  thumbnailUrl String?  @map("thumbnail_url")
  subjectId    String?  @map("subject_id")
  isPublic     Boolean  @default(false) @map("is_public")
  createdAt    DateTime @default(now()) @map("created_at")
  student      User     @relation("StudentPortfolio", fields: [studentId], references: [id], onDelete: Cascade)
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject      Subject? @relation(fields: [subjectId], references: [id])

  @@map("portfolio_items")
}

model StudentXP {
  studentId        String   @id @map("student_id")
  totalXP          Int      @default(0) @map("total_xp")
  level            Int      @default(1)
  currentStreak    Int      @default(0) @map("current_streak")
  longestStreak    Int      @default(0) @map("longest_streak")
  lastActivityDate DateTime? @map("last_activity_date")
  updatedAt        DateTime @updatedAt @map("updated_at")
  student          User     @relation("StudentXP", fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_xp")
}

model TimetablePeriod {
  id           String           @id @default(uuid())
  schoolId     String           @map("school_id")
  name         String
  startTime    String           @map("start_time")
  endTime      String           @map("end_time")
  periodNumber Int              @map("period_number")
  school       School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  slots        TimetableSlot[]

  @@unique([schoolId, periodNumber])
  @@map("timetable_periods")
}

model TimetableSlot {
  id            String          @id @default(uuid())
  schoolId      String          @map("school_id")
  classId       String          @map("class_id")
  subjectId     String          @map("subject_id")
  teacherId     String?         @map("teacher_id")
  periodId      String          @map("period_id")
  dayOfWeek     Int             @map("day_of_week")
  room          String?
  color         String?
  effectiveFrom DateTime        @map("effective_from")
  effectiveUntil DateTime?      @map("effective_until")
  createdAt     DateTime        @default(now()) @map("created_at")
  school        School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class         Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject       Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher       User?           @relation("TeacherSlots", fields: [teacherId], references: [id])
  period        TimetablePeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@map("timetable_slots")
}

model SchoolEvent {
  id             String   @id @default(uuid())
  schoolId       String   @map("school_id")
  title          String
  description    String?
  eventType      String   @map("event_type")
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  affectsClasses String?  @map("affects_classes")
  createdBy      String   @map("created_by")
  color          String?
  createdAt      DateTime @default(now()) @map("created_at")
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  creator        User     @relation("EventCreator", fields: [createdBy], references: [id])

  @@map("school_events")
}
