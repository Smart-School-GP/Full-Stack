# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=file:/app/data/school.db
DATABASE_PROVIDER=sqlite

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=1d

# ─── CORS ────────────────────────────────────────────────────────────────────
# In production, set to your actual domain (must be https://)
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated list of additional allowed origins
# ALLOWED_ORIGINS=https://app.yourschool.com,https://admin.yourschool.com

# ─── Service URLs ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8002

# ─── Monitoring & Alerting ───────────────────────────────────────────────────
# Sentry DSN for error tracking (get from sentry.io)
SENTRY_DSN=

# ─── Email (for password reset) ──────────────────────────────────────────────
# Leave empty to disable email (reset URLs will be logged in development)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourschool.com

# ─── File uploads ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20

# ─── Cron ────────────────────────────────────────────────────────────────────
CRON_TIMEZONE=UTC
