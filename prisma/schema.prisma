generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model School {
  id        String   @id @default(uuid())
  name      String
  city      String?
  country   String?
  createdAt DateTime @default(now()) @map("created_at")

  users    User[]
  classes  Class[]

  @@map("schools")
}

model User {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String
  createdAt    DateTime @default(now()) @map("created_at")

  school          School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentClasses  StudentClass[]
  teacherClasses  TeacherClass[]
  teacherSubjects Subject[]
  grades          Grade[]
  finalGrades     FinalGrade[]
  parentStudents  ParentStudent[] @relation("ParentRelation")
  studentParents  ParentStudent[] @relation("StudentRelation")

  @@map("users")
}

model Class {
  id         String   @id @default(uuid())
  schoolId   String   @map("school_id")
  name       String
  gradeLevel Int?     @map("grade_level")
  createdAt  DateTime @default(now()) @map("created_at")

  school   School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students StudentClass[]
  teachers TeacherClass[]
  subjects Subject[]

  @@map("classes")
}

model StudentClass {
  studentId String @map("student_id")
  classId   String @map("class_id")

  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([studentId, classId])
  @@map("student_classes")
}

model TeacherClass {
  teacherId String @map("teacher_id")
  classId   String @map("class_id")

  teacher User  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([teacherId, classId])
  @@map("teacher_classes")
}

model Subject {
  id        String   @id @default(uuid())
  classId   String   @map("class_id")
  teacherId String?  @map("teacher_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  class            Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher          User?             @relation(fields: [teacherId], references: [id])
  gradingAlgorithm GradingAlgorithm?
  assignments      Assignment[]
  finalGrades      FinalGrade[]

  @@map("subjects")
}

model GradingAlgorithm {
  id        String   @id @default(uuid())
  subjectId String   @unique @map("subject_id")
  weights   String
  updatedAt DateTime @updatedAt @map("updated_at")

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@map("grading_algorithms")
}

model Assignment {
  id        String   @id @default(uuid())
  subjectId String   @map("subject_id")
  title     String
  type      String
  maxScore  Float    @default(100) @map("max_score")
  createdAt DateTime @default(now()) @map("created_at")

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  grades  Grade[]

  @@map("assignments")
}

model Grade {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  assignmentId String   @map("assignment_id")
  score        Float
  createdAt    DateTime @default(now()) @map("created_at")

  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([studentId, assignmentId])
  @@map("grades")
}

model FinalGrade {
  id         String   @id @default(uuid())
  studentId  String   @map("student_id")
  subjectId  String   @map("subject_id")
  finalScore Float?   @map("final_score")
  updatedAt  DateTime @updatedAt @map("updated_at")

  student User    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@map("final_grades")
}

model ParentStudent {
  parentId  String @map("parent_id")
  studentId String @map("student_id")

  parent  User @relation("ParentRelation", fields: [parentId], references: [id], onDelete: Cascade)
  student User @relation("StudentRelation", fields: [studentId], references: [id], onDelete: Cascade)

  @@id([parentId, studentId])
  @@map("parent_students")
}
